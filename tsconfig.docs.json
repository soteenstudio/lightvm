{
  "compilerOptions": {
    "types": ["node"],
    "target": "ESNext",
    "lib": ["es5", "es6", "es7", "es2022", "dom"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "./docs/.vitepress",
    "typeRoots": ["./docs/types", "./node_modules/@types"],
    "sourceMap": true,
    "outDir": "./docs/dist",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "./types"
  },
  "include": ["./docs/.vitepress/**/*"],
  "exclude": ["tests", "./docs/types/**/*", "./docs/examples/**/*"]
}
