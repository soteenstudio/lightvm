{
  "name": "lightvm",
  "version": "0.1.0-alpha.4",
  "description": "A capability-based virtual machine designed for secure, predictable, and optimized bytecode execution.",
  "author": "SoTeen Studio",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/soteenstudio/lightvm.git"
  },
  "type": "module",
  "typings": "./typings/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.min.mjs",
      "require": "./dist/index.min.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/index.min.cjs",
    "dist/index.min.mjs",
    "typings"
  ],
  "scripts": {
    "build": "node ./esbuild.config.js",
    "build:release": "node ./build-script.js --local --silent",
    "build:debug": "node ./build-script.js --local --debug --silent",
    "typecheck": "tsc",
    "prettier": "npx prettier . --write"
  },
  "keywords": [
    "lightvm",
    "virtual machine",
    "rust",
    "typescript"
  ],
  "dependencies": {
    "chalk": "^5.6.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "esbuild": "^0.28.0",
    "prettier": "3.8.3"
  }
}
