{
  "name": "lightvm",
  "version": "v0.1.0-alpha.5",
  "description": "A capability-based virtual machine designed for secure, predictable, and optimized bytecode execution.",
  "author": "SoTeen Studio",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/soteenstudio/lightvm.git"
  },
  "bugs": {
    "url": "https://github.com/soteenstudio/lightvm/issues"
  },
  "homepage": "https://github.com/soteenstudio/lightvm#readme",
  "type": "module",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/index.min.mjs",
      "require": "./dist/index.min.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/index.min.cjs",
    "dist/index.min.mjs",
    "typings"
  ],
  "scripts": {
    "bench:rust": "cargo bench --manifest-path ./tests/benchmark/rust/Cargo.toml",
    "bench:ts": "node ts-bench.js",
    "build": "node ./esbuild.config.js",
    "build:release": "node ./build-script.js --local --silent",
    "build:debug": "node ./build-script.js --local --debug --silent",
    "typecheck": "tsc",
    "prettier": "npx prettier . --write",
    "eslint": "npx eslint . --fix",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{js,ts,jsx,tsx}": [
      "sh -c 'tsc'",
      "eslint --fix",
      "prettier --write"
    ],
    "*.rs": [
      "sh -c 'cargo fmt --'",
      "sh -c 'cargo clippy --color always -- -D warnings'"
    ]
  },
  "keywords": [
    "lightvm",
    "virtual machine",
    "rust",
    "typescript"
  ],
  "dependencies": {
    "chalk": "^5.6.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@types/node": "^25.9.1",
    "@typescript-eslint/parser": "^8.60.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "eslint-plugin-headers": "^1.3.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "3.8.3",
    "tinybench": "^6.0.2",
    "tsx": "^4.22.3"
  }
}
